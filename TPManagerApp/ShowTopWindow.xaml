<Window x:Class="TPManagerApp.ShowTopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Топ Категорій"
        Height="450"
        Width="700">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">

            <TextBlock Text="Період:"
                       VerticalAlignment="Center"
                       Margin="0 0 10 0"/>

            <ComboBox x:Name="PeriodBox"
                      Width="150"
                      SelectionChanged="PeriodBox_SelectionChanged">
                <ComboBoxItem Content="День"/>
                <ComboBoxItem Content="Тиждень"/>
                <ComboBoxItem Content="Місяць"/>
                <ComboBoxItem Content="Рік"/>

            </ComboBox>

        </StackPanel>

        <ListBox x:Name="TopList"
                 Grid.Row="1"
                 FontSize="14"/>
    </Grid>
</Window>