<Window x:Class="TPManagerApp.Registration_Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registration" Height="450" Width="400">

    <Grid>
        <DockPanel x:Name="RegistrationPanel" Margin="50">

            <Label DockPanel.Dock="Top" HorizontalAlignment="Center" FontSize="19">
                Registration
            </Label>

            <Label DockPanel.Dock="Top">Name</Label>
            <TextBox x:Name="NameBox" Width="350" DockPanel.Dock="Top"/>

            <Label DockPanel.Dock="Top">Surname</Label>
            <TextBox x:Name="SurnameBox" Width="350" DockPanel.Dock="Top"/>

            <Label DockPanel.Dock="Top">Email</Label>
            <TextBox x:Name="EmailBox" Width="350" DockPanel.Dock="Top"/>

            <Label DockPanel.Dock="Top">Password</Label>
            <PasswordBox x:Name="PasswordBox1" Width="350" DockPanel.Dock="Top"/>

            <Label DockPanel.Dock="Top">Confirm Password</Label>
            <PasswordBox x:Name="PasswordBox2" Width="350" DockPanel.Dock="Top"/>

            <Button DockPanel.Dock="Top"
                    Background="Green"
                    Foreground="White"
                    Height="30"
                    Click="Register_Click">
                registration
            </Button>

        </DockPanel>
        <StackPanel x:Name="SuccessPanel" Visibility="Hidden" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Ви успішно зареєструвались!" FontSize="18" Margin="0,0,0,20" HorizontalAlignment="Center"/>
            <Button Content="Увійти в систему" 
            Width="200" 
            Height="40" 
            Background="Green" 
            Foreground="White" 
            Click="Button_Click"/>
        </StackPanel>


    </Grid>
</Window>