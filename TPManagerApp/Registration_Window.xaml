<Window x:Class="TPManagerApp.Registration_Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Title="Registration" Height="550" Width="450" WindowStartupLocation="CenterScreen">
    <Grid>
        <Border x:Name="RegistrationPanel" VerticalAlignment="Center" HorizontalAlignment="Center" 
                Background="White" CornerRadius="20" Padding="30" Width="360" Height="460">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" Color="#D0D7E1" ShadowDepth="4" Opacity="0.6"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Registration" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15" Foreground="#333"/>

                    <TextBlock Text="Name" Foreground="Gray" Margin="0,0,0,2" FontSize="11"/>
                    <TextBox x:Name="NameBox" Padding="5,5" Margin="0,0,0,10" BorderThickness="0,0,0,1.5" BorderBrush="#DDD" FontSize="13"/>

                    <TextBlock Text="Surname" Foreground="Gray" Margin="0,0,0,2" FontSize="11"/>
                    <TextBox x:Name="SurnameBox" Padding="5,5" Margin="0,0,0,10" BorderThickness="0,0,0,1.5" BorderBrush="#DDD" FontSize="13"/>

                    <TextBlock Text="Email" Foreground="Gray" Margin="0,0,0,2" FontSize="11"/>
                    <TextBox x:Name="EmailBox" Padding="5,5" Margin="0,0,0,10" BorderThickness="0,0,0,1.5" BorderBrush="#DDD" FontSize="13"/>

                    <TextBlock Text="Password" Foreground="Gray" Margin="0,0,0,2" FontSize="11"/>
                    <PasswordBox x:Name="PasswordBox1" Padding="5,5" Margin="0,0,0,10" BorderThickness="0,0,0,1.5" BorderBrush="#DDD" FontSize="13"/>

                    <TextBlock Text="Confirm Password" Foreground="Gray" Margin="0,0,0,2" FontSize="11"/>
                    <PasswordBox x:Name="PasswordBox2" Padding="5,5" Margin="0,0,0,20" BorderThickness="0,0,0,1.5" BorderBrush="#DDD" FontSize="13"/>

                    <Button Content="Register" Click="Register_Click" Height="40" Background="#000" Foreground="White" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,10">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="20"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Back to Login" Click="Button_Click" Height="40" Background="White" Foreground="#555" FontWeight="Normal" Cursor="Hand" BorderBrush="#DDD" BorderThickness="1.5">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="20"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border x:Name="SuccessPanel" Visibility="Hidden" VerticalAlignment="Center" HorizontalAlignment="Center" Background="White" CornerRadius="20" Padding="40" Width="360" Height="200">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" Color="#D0D7E1" ShadowDepth="4" Opacity="0.6"/>
            </Border.Effect>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="✓" FontSize="44" Foreground="Green" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Ви успішно зареєструвались!" FontSize="16" FontWeight="SemiBold" Foreground="#333" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>