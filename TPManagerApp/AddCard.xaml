<Window x:Class="TPManagerApp.AddCard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Додати категорію"
        Height="400"
        Width="300"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Назва Банку"
                       Margin="0,5,0,5"/>

            <TextBox x:Name="BankBox"
                     Height="30"/>


            <TextBlock Text="Номер карти"
                       Margin="0,5,0,5"/>

            <TextBox x:Name="NumberBox"
                     Height="30"/>

            <TextBlock Text="Баланс на карті"
                       Margin="0,5,0,5"/>

            <TextBox x:Name="CashBox"
                     Height="30"/>

            <Button Content="Додати"
                    Height="35"
                    Margin="0,30,0,0"
                    Background="Green"
                    Foreground="White"
                    Click="Button_Click"/>
        </StackPanel>
    </Grid>
</Window>