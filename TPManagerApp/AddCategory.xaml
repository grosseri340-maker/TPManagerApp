<Window x:Class="TPManagerApp.AddCategory"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Додати категорію"
        Height="200"
        Width="300"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Назва категорії"
                       Margin="0,5,0,5"/>

            <TextBox x:Name="CategoryNameBox"
                     Height="30"/>

            <Button Content="Додати"
                    Height="35"
                    Margin="0,30,0,0"
                    Background="Green"
                    Foreground="White"
                    Click="Button_Click"/>
        </StackPanel>
    </Grid>
</Window>