<Window x:Class="TPManagerApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TPManagerApp"
        mc:Ignorable="d"
        Title="LoginWindow" Height="450" Width="800">
    <Grid>
        <Border VerticalAlignment="Center" HorizontalAlignment="Center" 
             Background="White" CornerRadius="20" Padding="40" Width="320">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" Color="#D0D7E1" ShadowDepth="4" Opacity="0.6"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Login" FontSize="28" FontWeight="Bold" 
                        HorizontalAlignment="Center" Margin="0,0,0,30" Foreground="#333"/>

                <TextBlock Text="User Name" Foreground="Gray" Margin="0,0,0,5" FontSize="12"/>
                <TextBox x:Name="txtUser" Padding="5,8" Margin="0,0,0,20" 
                      BorderThickness="0,0,0,1.5" BorderBrush="#DDD" FontSize="14"/>

                <TextBlock Text="Password" Foreground="Gray" Margin="0,0,0,5" FontSize="12"/>
                <PasswordBox x:Name="txtPass" Padding="5,8" Margin="0,0,0,35" 
                          BorderThickness="0,0,0,1.5" BorderBrush="#DDD" FontSize="14"/>

                <Button Content="Login" Click="LoginButton_Click" Height="45" 
                     Background="#000" Foreground="White" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="22"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
